# Copy to .env (or `export` these in your shell) to swap LLM providers.
# Default is `placeholder` which needs no key — useful for wiring up the UI.

# ── Placeholder (default, no LLM call) ─────────────────────────────────
LLM_PROVIDER=placeholder

# ── Google Gemini (free tier available) ────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.5-flash-lite # also: gemini-2.5-flash

# ── OpenAI ─────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-5.5  # also: gpt-4o, gpt-4o-mini

# ── Pioneer OpenAI-compatible endpoint ────────────────────────────────
# LLM_PROVIDER=pioneer
# LLM_API_KEY=pio_sk_...
# LLM_MODEL=eaf2d9b9-04b9-411f-a7cd-7e202c4270cc
# LLM_BASE_URL=https://api.pioneer.ai/v1

# ── Comparison flow: two OpenAI-style APIs called in parallel ─────────
# /api/process-file calls both providers and writes the GPT-labelled output
# to the database while keeping the Qwen output for side-by-side display.
# Both endpoints must speak the OpenAI Chat Completions schema.
GPT_LLM_API_KEY=sk-...
GPT_LLM_BASE_URL=https://api.openai.com/v1
GPT_LLM_MODEL=gpt-5.5
QWEN_LLM_API_KEY=pio_sk_...
QWEN_LLM_BASE_URL=https://api.pioneer.ai/v1
QWEN_LLM_MODEL=56b86950-526e-4550-8f36-2b86ebcfba5d

# ── Anthropic ──────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6

# ── OpenRouter (any model behind one key) ──────────────────────────────
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-sonnet-4-6

# ── Groq ───────────────────────────────────────────────────────────────
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# ── Local Ollama ───────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
